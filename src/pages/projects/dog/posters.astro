---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Nicholas Trigger - Dog Activity Tracker Posters" sideBarActiveItemID="projects" includeSidebar={false}>
  <div class="flex items-center justify-between mb-4 max-w-screen-xl mx-auto px-2">
    <div>
      <a href="/projects/dog" class="btn btn-ghost btn-sm gap-1 -ml-2 mb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Back to project
      </a>
      <h1 class="text-3xl font-bold">Dog Activity Trackers — Posters</h1>
      <p class="text-base-content/60 text-sm mt-1">Duke University EGR 101 Foundry · Saving Grace Animal Shelter</p>
    </div>
  </div>

  <!-- Tab switcher -->
  <div role="tablist" class="tabs tabs-box mb-4 max-w-screen-xl mx-auto px-2">
    <input type="radio" name="poster_tabs" role="tab" class="tab" aria-label="Team MAAAC — Activity Tracker" checked />
    <div role="tabpanel" class="tab-content pt-4">
      <div class="flex items-center justify-between mb-2 px-1">
        <p class="text-sm text-base-content/60">Alexandre Dias, Ari Dixit, Arshaan Sayed, Conrad Qu, Mila Prakapenka</p>
        <a href="/dog1poster.pdf" download class="btn btn-primary btn-sm gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download
        </a>
      </div>
      <div class="w-full rounded-xl overflow-hidden shadow-2xl border border-base-300">
        <object
          data="/dog1poster.pdf#toolbar=1&view=FitH"
          type="application/pdf"
          style="width: 100%; height: 88vh; min-height: 600px; display: block;"
        >
          <div class="flex flex-col items-center justify-center gap-4 p-12 text-base-content/60">
            <p>Your browser doesn't support inline PDFs.</p>
            <a href="/dog1poster.pdf" target="_blank" class="btn btn-primary">Open PDF</a>
          </div>
        </object>
      </div>
    </div>

    <input type="radio" name="poster_tabs" role="tab" class="tab" aria-label="Team 2 — Dog Fitness Tracker" />
    <div role="tabpanel" class="tab-content pt-4">
      <div class="flex items-center justify-between mb-2 px-1">
        <p class="text-sm text-base-content/60">Sam Patterson, Pablo Garza T, Yiannis Lempidakis, John Button, Jacob Hills</p>
        <a href="/dog2poster.pdf" download class="btn btn-primary btn-sm gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download
        </a>
      </div>
      <div class="w-full rounded-xl overflow-hidden shadow-2xl border border-base-300">
        <object
          data="/dog2poster.pdf#toolbar=1&view=FitH"
          type="application/pdf"
          style="width: 100%; height: 88vh; min-height: 600px; display: block;"
        >
          <div class="flex flex-col items-center justify-center gap-4 p-12 text-base-content/60">
            <p>Your browser doesn't support inline PDFs.</p>
            <a href="/dog2poster.pdf" target="_blank" class="btn btn-primary">Open PDF</a>
          </div>
        </object>
      </div>
    </div>
  </div>
</BaseLayout>
