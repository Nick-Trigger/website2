---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Nicholas Trigger - CLABSI Poster" sideBarActiveItemID="projects" includeSidebar={false}>
  <div class="flex items-center justify-between mb-4 max-w-screen-xl mx-auto px-2">
    <div>
      <a href="/projects/clabsi" class="btn btn-ghost btn-sm gap-1 -ml-2 mb-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Back to project
      </a>
      <h1 class="text-3xl font-bold">CLABSI — Final Poster</h1>
      <p class="text-base-content/60 text-sm mt-1">Duke University Biomedical Engineering · People's Choice Award</p>
    </div>
    <a href="/CLABSI_Final_Poster_2026_V2.pdf" download class="btn btn-primary btn-sm gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      Download PDF
    </a>
  </div>

  <div class="w-full rounded-xl overflow-hidden shadow-2xl border border-base-300">
    <object
      data="/CLABSI_Final_Poster_2026_V2.pdf#toolbar=1&view=FitH"
      type="application/pdf"
      style="width: 100%; height: 90vh; min-height: 600px; display: block;"
    >
      <div class="flex flex-col items-center justify-center gap-4 p-12 text-base-content/60">
        <p>Your browser doesn't support inline PDFs.</p>
        <a href="/CLABSI_Final_Poster_2026_V2.pdf" target="_blank" class="btn btn-primary">
          Open PDF
        </a>
      </div>
    </object>
  </div>
</BaseLayout>
