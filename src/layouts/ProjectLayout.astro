---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title: string;
  description: string;
  heroImage?: string | string[];
  badge?: string;
  tags?: string[];
  githubUrl?: string;
  docs?: { title: string; url: string; description?: string }[];
  frontmatter?: {
    title: string;
    description: string;
    heroImage?: string | string[];
    badge?: string;
    tags?: string[];
    githubUrl?: string;
    docs?: { title: string; url: string; description?: string }[];
  };
}

const fm = Astro.props.frontmatter ?? Astro.props;
const { title, description, badge, tags = [], githubUrl, docs = [] } = fm;

const rawHero = fm.heroImage;
const images: string[] = Array.isArray(rawHero) ? rawHero : rawHero ? [rawHero] : [];
const hasCarousel = images.length > 1;
---

<BaseLayout title={`Nicholas Trigger - ${title}`} sideBarActiveItemID="projects">
  <!-- Hero -->
  <div class="mb-8">

    {images.length === 1 && (
      <div class="w-full rounded-xl overflow-hidden mb-6 bg-neutral shadow-2xl max-h-72 flex items-center justify-center">
        <img src={images[0]} alt={title} class="w-full object-contain max-h-72" />
      </div>
    )}

    {hasCarousel && (
      <div class="relative w-full rounded-xl overflow-hidden mb-6 bg-neutral shadow-2xl" style="height: 18rem;" data-carousel>
        <!-- Sliding track -->
        <div class="flex h-full" style="transition: transform 0.5s ease-in-out;" data-carousel-track>
          {images.map((img, i) => (
            <div class="w-full flex-shrink-0 flex items-center justify-center h-full">
              <img src={img} alt={`${title} — image ${i + 1}`} class="w-full object-contain max-h-72" />
            </div>
          ))}
        </div>

        <!-- Arrows -->
        <button
          class="absolute left-3 top-1/2 -translate-y-1/2 btn btn-circle btn-sm bg-base-100/70 hover:bg-base-100 border-0 shadow"
          aria-label="Previous image"
          data-carousel-prev
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button
          class="absolute right-3 top-1/2 -translate-y-1/2 btn btn-circle btn-sm bg-base-100/70 hover:bg-base-100 border-0 shadow"
          aria-label="Next image"
          data-carousel-next
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>

        <!-- Dot indicators -->
        <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2" data-carousel-dots>
          {images.map((_, i) => (
            <button
              class={`w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-primary w-4' : 'bg-base-content/30'}`}
              aria-label={`Go to image ${i + 1}`}
              data-carousel-dot={i}
            />
          ))}
        </div>
      </div>
    )}

    <div class="flex flex-wrap items-start gap-3 mb-3">
      <h1 class="text-4xl font-bold flex-1">{title}</h1>
      {badge && <span class="badge badge-secondary text-sm self-start mt-2">{badge}</span>}
    </div>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.map((tag) => (
          <span class="badge badge-outline">{tag}</span>
        ))}
      </div>
    )}

    <p class="text-base-content/80 text-lg mb-4">{description}</p>

    {githubUrl && (
      <a href={githubUrl} target="_blank" rel="noopener noreferrer"
        class="btn btn-primary gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    )}
  </div>

  <div class="divider my-2"></div>

  <!-- Main content (prose-styled markdown) -->
  <div class="prose prose-lg max-w-none
    prose-headings:font-bold
    prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-3
    prose-h3:text-xl prose-h3:mt-6 prose-h3:mb-2
    prose-table:w-full
    prose-td:py-2 prose-td:px-3
    prose-th:py-2 prose-th:px-3
    prose-code:text-sm
    dark:prose-invert">
    <slot />
  </div>

  <!-- Documents section -->
  {docs.length > 0 && (
    <>
      <div class="divider my-6"></div>
      <div>
        <h2 class="text-2xl font-bold mb-4">Project Documents</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {docs.map((doc) => (
            <a href={doc.url} target="_blank" rel="noopener noreferrer"
              class="card bg-neutral shadow-md hover:shadow-xl transition-shadow border border-base-300 hover:border-primary no-underline">
              <div class="card-body p-4 gap-1">
                <div class="flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                  </svg>
                  <span class="font-semibold">{doc.title}</span>
                </div>
                {doc.description && (
                  <p class="text-sm text-base-content/70 m-0">{doc.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </>
  )}
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('[data-carousel-track]')!;
    const dotBtns = carousel.querySelectorAll<HTMLElement>('[data-carousel-dot]');
    const total = track.children.length;
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dotBtns.forEach((dot, i) => {
        const active = i === current;
        dot.classList.toggle('bg-primary', active);
        dot.classList.toggle('w-4', active);
        dot.classList.toggle('bg-base-content/30', !active);
        dot.classList.toggle('w-2', !active);
      });
    }

    function resetTimer() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    carousel.querySelector('[data-carousel-prev]')?.addEventListener('click', () => {
      goTo(current - 1);
      resetTimer();
    });

    carousel.querySelector('[data-carousel-next]')?.addEventListener('click', () => {
      goTo(current + 1);
      resetTimer();
    });

    dotBtns.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        goTo(i);
        resetTimer();
      });
    });

    resetTimer();
  });
</script>
